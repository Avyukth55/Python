from abc import ABC, abstractmethod
class Animal(ABC):
    def move(self):
        pass
class Snake(Animal):
    def move(self):
        print("I can crawl")
class Penguin(Animal):
    def move(self):
        print("I can waddle")
class Bird(Animal):
    def move(self):
        print("I can fly")
class Cheetah(Animal):
    def move(self):
        print("I can run")