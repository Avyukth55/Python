class Person():
    def __init__(self, name, idnumber):
        self.name=name
        self.idnumber=idnumber
    def display(self):
        print(f"Name: {self.name}, ID number: {self.idnumber}")
class Employee(Person):
    def __init__(self, name, idnumber, salary, post):
        self.name=name
        self.idnumber=idnumber
        self.salary=salary
        self.post=post
    def show(self):
        super().display()
